{
  "version": 2,
  "name": "technomads",
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "css/*.css", "use": "@vercel/static" },
    { "src": "js/*.js", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" },
    { "src": "projects/**/*.html", "use": "@vercel/static" },
    { "src": "entertainment/**/*.html", "use": "@vercel/static" }
  ],
  "trailingSlash": false
}